    %% PLANE F — 真值/不变量与排障
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_F["F. 真值 / 不变量 / 排障"]
        direction TB

        subgraph MODEL_POLICY["27. Model policy invariant"]
            direction TB
            MP1["No local per-account model whitelist<br/>accounts.credentials.model_mapping deleted from all rows"]
            MP2["DB constraint accounts_credentials_no_model_mapping<br/>blocks reintroduction through admin/API/import paths"]
            MP3["Scheduler may filter by platform/capability/rate/concurrency<br/>but must not reject unknown model names locally"]
            MP4["Unknown or bad model is forwarded to selected upstream<br/>upstream returns model_not_found/400/etc<br/>that is a provider error, not local doorkeeping"]
            MP1 --> MP2 --> MP3 --> MP4
        end

        subgraph TROUBLESHOOT["14. Error triage decision table"]
            direction TB
            T503["No available accounts<br/>look at group binding, account_groups, schedulable,<br/>temp_unschedulable, Redis scheduler cache, live capacity<br/>not local model whitelist"]
            T400["HTTP 400 after account_selected<br/>look at selected account upstream and exact request body/protocol<br/>not fixed by adding more schedulable accounts"]
            T5XX["HTTP 5xx after account_selected<br/>upstream unstable; failover circuit temp-unschedules account<br/>pool still needs at least one alternate healthy account"]
            T424["MCP/API Error 424 wrapper<br/>inspect inner body and sub2api logs by request id"]
        end

        subgraph STABILITY_INVARIANTS["28. Stability invariants / 号源适配抽象 (架构级)"]
            direction TB
            SI1["AXIS-1 认证形态<br/>API key / OAuth refresh / Cookie+cf / SVC-Account JWT / sigv4 / 反代<br/>抽象目标: TokenRefresher 扩展为通用 CredentialProvider plugin<br/>加新认证族 = 新插件 + 一行配置, 不改 Go 主线"]
            SI2["AXIS-2 协议形态<br/>Anthropic / OpenAI chat / Responses / Gemini / Bedrock / Vertex<br/>抽象目标: native pass-through 已选, 维持原则<br/>所有未知字段透传, 不在网关侧裁剪"]
            SI3["AXIS-3 限额形态<br/>per-token / per-request / 订阅窗口 / 余额 / 月配额 / 并发<br/>抽象目标: 单一 AvailabilityOracle 收敛 4 store 状态<br/>(rate / temp_unsched / overload / error) 因果一致"]
            SI4["AXIS-4 失败语义<br/>(上游 × 状态码 × body 模式 → 动作) 四元组规则表<br/>动作: retry / failover / disable / cooldown / refresh / quarantine<br/>规则可热更新, 不写死在 Go"]
            SI5["AXIS-5 健康判定 (探活分级)<br/>L0 auth probe (models list, 0 token)<br/>L1 quota probe (count_tokens 或最小请求)<br/>L2 generation probe (完整 chat, 仅长期无真实流量号)<br/>失败语义沿 L0->L1->L2 因果上推"]

            SI6["FEEDBACK 真实流量信号 = 探活信号<br/>真实 forward 200 N 次 -> 推迟下次探活<br/>真实 5xx 比例突变 -> 立刻触发 L0 探活<br/>把熔断和探活两条链合并成单一反馈环"]
            SI7["BACKOFF 探活间隔 = 号动荡度的函数<br/>连续 N 次成功 -> 间隔 x2 封顶 2h<br/>真实 5xx -> 间隔 /2 下限 1min<br/>刚 recover -> 5min x3 强校验后入正常档<br/>探活预算自动从稳号腾给抖号"]
            SI8["EQUIV-CLASS 号源族<br/>同 OAuth 端点 / 同代理 / 同子网 / 同购买批次 = 一族<br/>同族同时坏掉 -> 一号探活成功后批量轻量复测<br/>避免 N 次重复烧 token, 加速归因"]
            SI9["LIMIT-LEARN 限额自学习<br/>真实 RPS + 成功率 -> 自动收敛安全配额 (AIMD)<br/>不靠人预填 RPM/TPM 规则<br/>号一进来半天后系统自学其容量曲线"]

            SI1 --> SI3
            SI2 --> SI4
            SI3 --> SI4
            SI4 --> SI5
            SI5 --> SI6
            SI6 --> SI7
            SI7 --> SI8
            SI8 --> SI9
        end
    end

