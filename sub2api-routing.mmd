%% sub2api 内部单图总览: 路由 + 鉴权 + 调度 + 转发 + 计费 + 支付 + OAuth/token + 监控 + 自愈 + 管理面
%% 更新: 2026-06-03 +08 / TLS fingerprint 平台限制放开 + OpenAI passthrough DoWithTLS
%% 证据: 运行容器日志、Postgres schema、Redis key、docker env、栈帧路径、backend/internal/server/routes 与 backend/internal/service 核心源码
%% 运行面: server-170 / container=sub2api / port=8080 / health=200
%% 关键 env: GATEWAY_DISABLE_MODEL_MAPPING=true, GATEWAY_SCHEDULING_LOAD_BATCH_ENABLED=true,
%%          GATEWAY_SCHEDULING_DB_FALLBACK_ENABLED=true, full_rebuild=300s, outbox_poll=1s
%% model_mapping 已从 accounts.credentials 全量删除，并由 DB constraint 禁止回写
%% 强制流式已上线: 文本生成入口统一 forceTextGenerationStream
%% failover 熔断已上线: 上游 5xx 触发 failover, 账号写入 temp_unschedulable_until=now+2m
%% per-account 403 软阈值已上线(2026-06-03): account.Credentials.temp_unschedulable_rules 命中关键词的 403 → 冷却N分钟而非硬 SetError; 与上面 5xx failover 是两条独立触发链(packyapi: error_code=403 keyword=bad_response_status_code 2min)

flowchart TB

    %% ═══════════════════════════════════════════════════════════════
    %% PLANE A — 入口与鉴权
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_A["A. 入口与鉴权"]
        direction TB

        subgraph RUNTIME["0. 运行真相源 / state owners"]
            direction TB
            DOCKER["Docker container: sub2api<br/>HTTP :8080<br/>health=/health/deps"]
            PG["Postgres: sub2api-postgres<br/>ent repositories are source of truth<br/>users/api_keys/groups/account_groups/accounts<br/>usage/billing/payment/subscription/settings/ops"]
            REDIS["Redis: sub2api-redis<br/>auth/key/subscription/rate cache<br/>sticky_session / scheduler snapshot<br/>concurrency slots / token cache / temp unsched"]
            ENV["env gates<br/>disable_model_mapping=true<br/>load_batch=true<br/>db_fallback=true<br/>outbox poll=1s / rebuild=300s<br/>DB forbids credentials.model_mapping"]
            DOCKER --- PG
            DOCKER --- REDIS
            DOCKER --- ENV
        end

        subgraph INGRESS["1. HTTP 入口 / Gin route layer"]
            direction TB
            CLIENT["Client<br/>Claude Code / Claude API compatible / OpenAI compatible<br/>key=sk-* or x-api-key<br/>model in body"]
            ROUTE{"path / protocol"}
            MSG["/v1/messages<br/>Anthropic Messages"]
            CHAT["/v1/chat/completions<br/>OpenAI Chat Completions"]
            RESP["/responses<br/>OpenAI Responses"]
            APIUSER["/api/v1/auth / user / keys / groups / usage<br/>frontend user plane"]
            PAYROUTE["/api/v1/payment/*<br/>orders / public config / webhooks / admin payment"]
            ADMIN["/api/v1/admin/*<br/>admin REST / MCP control"]
            HEALTH["/health/deps<br/>container health"]
            CLIENT --> ROUTE
            ROUTE --> MSG
            ROUTE --> CHAT
            ROUTE --> RESP
            ROUTE --> APIUSER
            ROUTE --> PAYROUTE
            ROUTE --> ADMIN
            ROUTE --> HEALTH
        end

        subgraph MIDDLEWARE["2. Gateway middleware chain"]
            direction TB
            LIMIT["RequestBodyLimit<br/>GATEWAY_MAX_BODY_SIZE"]
            REQID["ClientRequestID + request logger<br/>生成 client_request_id / request_id"]
            ENDPOINT["InboundEndpointMiddleware<br/>识别 endpoint/provider/protocol/model/body_bytes"]
            AUTH{"API key auth<br/>api_keys.key active?<br/>not deleted / not expired / quota ok"}
            GROUP_REQ{"RequireGroupAssignment<br/>api_key.group_id exists?"}
            E401["401 Unauthorized<br/>key 无效/禁用/过期"]
            E403["403 Forbidden / quota<br/>额度/IP/订阅限制"]
            E424["424 bad upstream response<br/>工具侧或 MCP 包装层可能显示为 API Error"]
            LIMIT --> REQID --> ENDPOINT --> AUTH
            AUTH -->|fail| E401
            AUTH -->|quota/ip/subscription fail| E403
            AUTH -->|ok| GROUP_REQ
            GROUP_REQ -->|no group| E403
        end
        MSG --> LIMIT
        CHAT --> LIMIT
        RESP --> LIMIT

        subgraph GROUPING["3. key -> group -> provider policy"]
            direction TB
            KEYMETA["api_keys<br/>例: claude key -> group1<br/>codex key -> group3"]
            GROUPMETA["groups<br/>group1: platform=anthropic<br/>group3: platform=openai"]
            PROTO{"protocol family"}
            ANTHRO["Anthropic path<br/>/v1/messages<br/>platform=anthropic"]
            OPENAI_CHAT["OpenAI-compatible Anthropic path<br/>/v1/chat/completions may route to anthropic accounts"]
            OPENAI_RESP["OpenAI path<br/>/responses routes to group3 openai accounts"]
            GROUP_REQ --> KEYMETA --> GROUPMETA --> PROTO
            PROTO --> ANTHRO
            PROTO --> OPENAI_CHAT
            PROTO --> OPENAI_RESP
        end

        subgraph USER_AUTH["16. User auth, settings, and API key lifecycle"]
            direction TB
            SETTINGS["SettingService<br/>runtime settings from DB<br/>registration/email verify/turnstile<br/>OIDC/LinuxDo/WeChat config<br/>model fallback, stream timeout, beta policy,<br/>rectifier, Claude Code version bounds"]
            REGISTER["AuthService.Register<br/>email policy + optional verify code<br/>password hash + user create<br/>promo/invitation/affiliate binding"]
            LOGIN["AuthService.Login/OAuth<br/>password or provider identity<br/>email-first bind defaults<br/>touch last login"]
            JWT["JWT access token + refresh token family<br/>ValidateToken / RefreshTokenPair<br/>revoke single/all sessions"]
            USER_PROFILE["UserService<br/>profile/password/concurrency<br/>auth identities bind/unbind<br/>TOTP / notify email"]
            KEY_LIFE["APIKeyService<br/>GenerateKey / custom key validation<br/>Create/List/Update/Delete<br/>group bind permission<br/>IP rules, quota, expiry, rate usage"]
            PUB_SETTINGS["public settings view<br/>frontend auth/payment/OAuth feature flags"]
            SETTINGS --> REGISTER --> JWT
            SETTINGS --> LOGIN --> JWT
            JWT --> USER_PROFILE
            JWT --> KEY_LIFE
            SETTINGS --> PUB_SETTINGS
            KEY_LIFE -.creates and updates.-> KEYMETA
        end
    end

    %% ═══════════════════════════════════════════════════════════════
    %% PLANE B — 调度与转发主链
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_B["B. 调度与转发主链"]
        direction TB

        subgraph STREAM_POLICY["4. Stream policy / force text generation streaming"]
            direction TB
            FORCE_STREAM["forceTextGenerationStream<br/>/v1/messages, /v1/chat/completions, /v1/responses,<br/>OpenAI-compatible messages/responses text paths<br/>set JSON stream=true before moderation, scheduling, and forward"]
            NON_TEXT["non-text endpoints excluded<br/>embeddings / images / count_tokens / models"]
            FORCE_STREAM -.does not apply.-> NON_TEXT
        end

        subgraph MODERATION["4b. Content moderation precheck"]
            direction TB
            MOD_START["content_moderation.gateway_check_start"]
            MOD_ENABLED{"moderation enabled?"}
            MOD_ALLOW["allowed=true<br/>continue"]
            MOD_BLOCK["blocked/flagged<br/>return moderation action"]
            MOD_START --> MOD_ENABLED
            MOD_ENABLED -->|disabled in logs| MOD_ALLOW
            MOD_ENABLED -->|enabled + flagged| MOD_BLOCK
        end

        subgraph STICKY["5. Sticky session"]
            direction TB
            HASH_SRC{"hash source"}
            META_HASH["metadata_user_id<br/>session_id + device_id<br/>Claude Code 常见"]
            BODY_HASH["message_content_fallback<br/>large body hash"]
            EMPTY_HASH["generated hash<br/>无 metadata 时生成"]
            CACHE_LOOKUP["Redis lookup<br/>sticky_session:{group_id}:{session_hash}"]
            BOUND{"bound_account_id > 0?"}
            STICKY_ACC["sticky_account_id candidate<br/>仍必须过调度门"]
            NO_STICKY["no sticky account<br/>走正常候选遍历"]
            HASH_SRC --> META_HASH --> CACHE_LOOKUP
            HASH_SRC --> BODY_HASH --> CACHE_LOOKUP
            HASH_SRC --> EMPTY_HASH --> CACHE_LOOKUP
            CACHE_LOOKUP --> BOUND
            BOUND -->|yes| STICKY_ACC
            BOUND -->|no| NO_STICKY
        end

        subgraph LOAD["6. Candidate loading / scheduler source"]
            direction TB
            ENTRY["sticky.scheduler_entry<br/>group_id, session_hash, model,<br/>sticky_account_id, load_batch, excluded_count"]
            LOAD_BATCH{"load_batch enabled?"}
            REDIS_SCHED["Redis scheduling cache<br/>sched:acc, sched:meta,<br/>concurrency slots"]
            DB_FALLBACK{"cache miss/stale/error<br/>db_fallback enabled?"}
            DB_QUERY["DB source of truth<br/>accounts join account_groups<br/>where group_id + platform + deleted_at is null"]
            REBUILD["outbox poll / full rebuild<br/>refresh scheduler cache"]
            CANDIDATES["candidate accounts<br/>ordered by account_groups.priority + account priority/load"]
            ENTRY --> LOAD_BATCH
            LOAD_BATCH -->|yes| REDIS_SCHED
            LOAD_BATCH -->|no| DB_QUERY
            REDIS_SCHED --> DB_FALLBACK
            DB_FALLBACK -->|yes| DB_QUERY
            DB_FALLBACK -->|no| CANDIDATES
            DB_QUERY --> CANDIDATES
            REBUILD -.refresh.-> REDIS_SCHED
        end

        subgraph SELECT["7. SelectAccountWithLoadAwareness / account gates"]
            direction TB
            TRY["Try candidate account<br/>sticky first, then normal candidates"]
            G_STATUS{"gate 1: schedulable state<br/>status=active<br/>schedulable=true<br/>not deleted<br/>not temp_unschedulable<br/>not overload / rate_limited"}
            G_MODEL{"gate 2: model support<br/>local whitelist removed<br/>scheduler must not reject by model name<br/>model is passed through to upstream"}
            G_MODEL_ROUTE{"gate 3: model rewrite<br/>removed for accounts.credentials.model_mapping<br/>no local alias table; upstream owns model validity"}
            G_LIMIT{"gate 4: limits<br/>model rate limit / RPM / concurrency<br/>daily-weekly-monthly group quota<br/>session window cost"}
            SLOT{"Acquire concurrency slot<br/>concurrency:account:{id}"}
            PICK["account_selected<br/>slot_acquired=true<br/>write sticky session if needed"]
            SKIP["skip account<br/>try next candidate"]
            NO_ACCOUNT["503 No available accounts<br/>sub2api scheduling layer<br/>no candidate passed gates"]
            TRY --> G_STATUS
            G_STATUS -->|fail| SKIP
            G_STATUS -->|pass| G_MODEL
            G_MODEL -->|fail| SKIP
            G_MODEL -->|pass| G_MODEL_ROUTE
            G_MODEL_ROUTE --> G_LIMIT
            G_LIMIT -->|fail| SKIP
            G_LIMIT -->|pass| SLOT
            SLOT -->|fail/wait timeout| SKIP
            SLOT -->|ok| PICK
            SKIP -->|more candidates| TRY
            SKIP -->|exhausted| NO_ACCOUNT
        end

        subgraph FORWARD["9. Forward / upstream request"]
            direction TB
            MAP_MODEL["Model passthrough<br/>outbound model = original request model<br/>local account model_mapping removed"]
            BUILD_REQ["Build upstream request<br/>account base_url + account api key<br/>text generation body already stream=true<br/>protocol-specific body transform"]
            SEND["HTTP upstream call<br/>account platform/type/provider"]
            UP_RESP{"upstream status"}
            PICK --> MAP_MODEL --> BUILD_REQ --> SEND --> UP_RESP
        end

        subgraph PROTOCOLS["17. Protocol adapters / platform-specific gateway services"]
            direction TB
            ANTH_MSG["GatewayService.Messages<br/>Anthropic messages -> upstream Claude-like account"]
            ANTH_COUNT["GatewayService.CountTokens<br/>unsupported for OpenAI groups"]
            ANTH_RESP["GatewayService.Responses<br/>Anthropic compatible Responses bridge"]
            ANTH_CHAT["GatewayService.ChatCompletions<br/>OpenAI-compatible request transformed to Anthropic where needed"]
            GEMINI_NATIVE["Gemini native /v1beta<br/>Google error writer<br/>models:list/get/generateContent/streamGenerateContent"]
            OPENAI_RESP_SVC["OpenAIGatewayService.Responses<br/>Codex/OpenAI Responses API<br/>previous_response_id/session/codex snapshot support"]
            OPENAI_CHAT_SVC["OpenAIGatewayService.ChatCompletions<br/>chat API, tools, image/embedding variants"]
            OPENAI_WS["ResponsesWebSocket / realtime<br/>GET /responses and WS QPS ops surface"]
            ANTI_FORCE["Antigravity forced platform<br/>/antigravity/v1 and /v1beta never mix normal group scheduling"]
            OPENAI_RESP_SVC --> OPENAI_WS
            OPENAI_CHAT_SVC --> OPENAI_WS
        end

        subgraph OPENAI_SCHED["18. OpenAI account scheduler / advanced routing"]
            direction TB
            OAI_REQ["OpenAI request context<br/>model, endpoint, previous_response_id,<br/>session_hash, codex mode, transport"]
            PREV_LAYER{"previous_response_id layer"}
            SESSION_LAYER{"session_hash layer"}
            LB_LAYER{"load_balance layer"}
            ADV_SETTINGS["advanced scheduler settings<br/>enabled layers, top-K, EWMA,<br/>transport/capability compatibility"]
            ERR_SCORE["EWMA error / TTFT / recent failure score<br/>429/403 reset signals<br/>WS snapshot state"]
            WEIGHTED_PICK["weighted top-K pick<br/>then account concurrency slot"]
            OAI_FALLBACK["fallback to DB/snapshot cache<br/>same source-of-truth rules as general scheduler"]
            OAI_REQ --> PREV_LAYER --> SESSION_LAYER --> LB_LAYER
            ADV_SETTINGS --> LB_LAYER
            ERR_SCORE --> LB_LAYER
        end
    end

    %% PLANE B 跨段连接
    ANTHRO --> FORCE_STREAM
    OPENAI_CHAT --> FORCE_STREAM
    OPENAI_RESP --> FORCE_STREAM
    FORCE_STREAM --> MOD_START
    MOD_ALLOW --> HASH_SRC
    STICKY_ACC --> ENTRY
    NO_STICKY --> ENTRY
    CANDIDATES --> TRY
    ANTHRO --> ANTH_MSG
    OPENAI_CHAT --> ANTH_CHAT
    OPENAI_RESP --> OPENAI_RESP_SVC
    MSG --> ANTH_COUNT
    GEMINI_NATIVE --> PROTO
    ANTI_FORCE --> PROTO
    OPENAI_RESP_SVC --> OAI_REQ
    OPENAI_CHAT_SVC --> OAI_REQ
    LB_LAYER --> WEIGHTED_PICK --> PICK
    LB_LAYER --> OAI_FALLBACK --> CANDIDATES

    %% ═══════════════════════════════════════════════════════════════
    %% PLANE C — 状态与自愈
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_C["C. 状态与自愈"]
        direction TB

        subgraph ERROR_SEMANTICS["10. Response/error semantics"]
            direction TB
            OK["200 success<br/>stream or non-stream relay to client"]
            USAGE["usage/cost accounting<br/>usage_logs / billing_usage_entries<br/>deferred last_used flush"]
            UP400["400 upstream non-retryable<br/>example: 错误的格式,请回退至无错误位置重新发送<br/>source=selected upstream account, not scheduler"]
            UP401["401/403 upstream auth/quota<br/>upstream key/credit/provider rejection"]
            UP429["429/rate limit<br/>mark rate_limited/reset when applicable"]
            UP5XX["5xx/timeout/network<br/>retry/failover if possible<br/>failover circuit writes temp_unschedulable_until=now+2m"]
            WRAP["sub2api error wrapper<br/>client may see data:{type:error,error:{type:upstream_error,message:Upstream request failed}}"]
            OK --> USAGE
            UP400 --> WRAP
            UP401 --> WRAP
            UP429 --> WRAP
            UP5XX --> WRAP
        end

        subgraph LIMITS_STATE["19. Limits and account state transitions"]
            direction TB
            MODEL_LIMIT["ModelRateLimitService<br/>model-specific RPM/TPM/window rules<br/>platform-specific 401/403/429/529 handling"]
            RATE_LIMIT["RateLimitService<br/>account rate_limited/reset_at<br/>Gemini quota precheck<br/>session window usage update<br/>stream timeout handling"]
            CONCURRENCY["ConcurrencyService<br/>account/user slot acquire/release<br/>waiting counts, batch load<br/>cleanup worker"]
            TEMP_UNSCHED["Temp unschedulable cache/DB<br/>refresh fail, upstream 5xx failover circuit, overload cooldown<br/>scheduler cache excludes until recovery"]
            CLEAR_STATE["admin clear_error / clear_rate_limit<br/>recover_state / reset_quota / schedulable toggle"]
            MODEL_LIMIT --> RATE_LIMIT --> CONCURRENCY
        end

        subgraph TOKEN_OAUTH["20. OAuth and token lifecycle"]
            direction TB
            OAUTH_ADMIN["admin OAuth/account onboarding<br/>OpenAI/Gemini/Antigravity auth URL<br/>code exchange/cookie import/service account"]
            TOKEN_IF["TokenRefresher interface<br/>Claude/OpenAI/Gemini/Antigravity implementations<br/>CacheKey / CanRefresh / NeedsRefresh / Refresh"]
            TOKEN_PROVIDER["request-path token providers<br/>GetAccessToken<br/>cache lookup + refresh skew<br/>distributed refresh locks"]
            TOKEN_REFRESH["TokenRefreshService background loop<br/>list active accounts<br/>refreshWithRetry<br/>write credentials + invalidate token cache"]
            PRIVACY["post-refresh privacy actions<br/>OpenAI/Antigravity privacy settings<br/>proxy-aware refresh APIs"]
            REFRESH_FAIL["repeated refresh failure<br/>SetError or temp unschedulable<br/>scheduler excludes account"]
            OAUTH_ADMIN --> TOKEN_IF
            TOKEN_IF --> TOKEN_PROVIDER
            TOKEN_IF --> TOKEN_REFRESH --> PRIVACY
            TOKEN_REFRESH -->|failure| REFRESH_FAIL
        end

        subgraph HEAL["12. Scheduled test runner / auto-heal"]
            direction TB
            TICK["scheduled_test_runner tick<br/>found due plans + baseline recovery accounts"]
            PLAN["scheduled_test_plans<br/>account_id + model_id + cron + auto_recover"]
            BASELINE["baseline recovery scan<br/>enumerate all accounts<br/>disabled/error/unsched/blocked/error-message candidates<br/>skip due-plan accounts; 15m process throttle"]
            RUNTEST["RunTestBackground<br/>AccountTestService.TestAccountConnection"]
            TEST_OK{"test result success?"}
            RECOVER["RecoverAccountAfterSuccessfulTest<br/>clear error / rate limit / temp unschedulable<br/>return to scheduling"]
            STAY_BAD["keep disabled/error/rate_limited<br/>next cron retries"]
            TEST_503["observed scheduled test 503<br/>API returned Service temporarily unavailable"]
            TICK --> PLAN --> RUNTEST --> TEST_OK
            TICK --> BASELINE --> RUNTEST
            TEST_OK -->|yes + auto_recover| RECOVER
            TEST_OK -->|no| STAY_BAD
            RUNTEST -.can produce.-> TEST_503
        end
    end

    %% PLANE C 跨段连接
    UP_RESP -->|2xx| OK
    UP_RESP -->|400| UP400
    UP_RESP -->|401/403| UP401
    UP_RESP -->|429| UP429
    UP_RESP -->|5xx/timeout| UP5XX
    G_LIMIT --> MODEL_LIMIT
    CONCURRENCY --> SLOT
    UP401 --> RATE_LIMIT
    UP429 --> RATE_LIMIT
    UP5XX --> TEMP_UNSCHED
    TEMP_UNSCHED --> G_STATUS
    TOKEN_PROVIDER --> BUILD_REQ
    TOKEN_REFRESH -->|success| REBUILD
    REFRESH_FAIL --> TEMP_UNSCHED
    UP5XX -.may create healing signal.-> PLAN
    RECOVER -.refresh candidates.-> REBUILD
    CLEAR_STATE --> REBUILD

    %% ═══════════════════════════════════════════════════════════════
    %% PLANE D — 计费与商业
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_D["D. 计费与商业"]
        direction TB

        subgraph BILLING["21. Usage accounting and billing"]
            direction TB
            RECORD_USAGE["GatewayService.RecordUsage / OpenAIGateway record usage<br/>extract tokens/cache/image/request units<br/>deferred last_used flush"]
            PRICING["BillingService pricing resolution<br/>channel model pricing > remote LiteLLM/catalog > fallback<br/>token/per-request/image price<br/>service tier and long-context multipliers"]
            COST["CalculateCostUnified<br/>input/output/cache creation/cache read<br/>per request/image count/rate multiplier<br/>CostBreakdown"]
            WRITE_USAGE["write usage_logs and billing_usage_entries<br/>update api key quota/rate usage<br/>update subscription window cost"]
            USER_QUOTA["APIKey quota and expiry<br/>balance mode or subscription mode<br/>RunModeSimple skips billing enforcement"]
            SUB_WINDOWS["SubscriptionService<br/>assign/extend/revoke/list<br/>daily weekly monthly windows<br/>validate active group limits<br/>RecordUsage"]
            RECORD_USAGE --> PRICING --> COST --> WRITE_USAGE
            WRITE_USAGE --> SUB_WINDOWS
        end

        subgraph PAYMENT_DOMAIN["22. Payment / redeem / subscription fulfillment"]
            direction TB
            PAY_CONFIG["PaymentConfigService<br/>plans/providers/method instances<br/>limits and visible methods"]
            CREATE_ORDER["PaymentService.CreateOrder<br/>validate amount/plan/user/provider snapshot<br/>pending order"]
            PROVIDER_CALL["provider client<br/>checkout / JSAPI / QR / external payment URL"]
            WEBHOOK["PaymentWebhookProvider<br/>verify signature + parse event<br/>idempotent order lookup"]
            ORDER_STATE["Payment order lifecycle<br/>pending -> paid/recharging -> completed<br/>failed/refunded/cancelled/expired"]
            FULFILL["PaymentFulfillment<br/>balance recharge or subscription assignment<br/>quota window initialization"]
            REDEEM["RedeemService<br/>code validation/use<br/>balance or subscription grant"]
            AFFILIATE["AffiliateService<br/>invite code bind<br/>rebate accrual<br/>transfer affiliate quota<br/>admin custom rebate rates"]
            PAY_CONFIG --> CREATE_ORDER --> PROVIDER_CALL --> ORDER_STATE
            WEBHOOK --> ORDER_STATE --> FULFILL
            REDEEM --> FULFILL
            FULFILL --> SUB_WINDOWS
            FULFILL --> AFFILIATE
        end

        subgraph CHANNELS["23. Channels, provider catalog, monitors, passthrough rules"]
            direction TB
            PROVIDER_CAT["provider catalog / channel definitions<br/>platform capability, default base URL,<br/>model catalog and pricing metadata"]
            CHANNEL_CFG["channels and channel pricing<br/>group/account/channel restriction<br/>model/channel rate multiplier"]
            ERROR_RULES["error passthrough rules<br/>which upstream error/status/body can pass unchanged<br/>otherwise normalize to gateway error wrapper"]
            TLS_FP["TLS fingerprint profiles<br/>所有平台账号均可绑定 TLS profile (含 OpenAI apikey passthrough 路径)<br/>extra.enable_tls_fingerprint=true + tls_fingerprint_profile_id 即启用<br/>⚠ CF 前置 new-api 上游(packyapi 类)用 profile 5=chrome_135_h1only:<br/>Node.js 默认指纹/profile3 会触发 ForceAttemptHTTP2:false × h2 ALPN 协议错<br/>改 profile 必须同时 bump concurrency(缓存键含concurrency不含profile)<br/>解决 packyapi/tokenflux 等 CF JA3 拦截"]
            MONITOR_TPL["channel monitor templates<br/>HTTP checks, validation rules, challenge/SSRF guard"]
            MONITOR_RUN["channel monitor runner/checker/aggregator<br/>scheduled checks, status aggregation,<br/>admin/user monitor views"]
            PROVIDER_CAT --> CHANNEL_CFG
            MONITOR_TPL --> MONITOR_RUN
        end
    end

    %% PLANE D 跨段连接
    USAGE --> RECORD_USAGE
    WRITE_USAGE --> KEY_LIFE
    CHANNEL_CFG --> PRICING
    ERROR_RULES --> WRAP
    TLS_FP --> SEND
    FULFILL --> KEY_LIFE

    %% ═══════════════════════════════════════════════════════════════
    %% PLANE E — 管理面与运维
    %% ═══════════════════════════════════════════════════════════════
    subgraph PLANE_E["E. 管理面与运维"]
        direction TB

        subgraph MGMT["13. Admin/MCP mutation paths"]
            direction TB
            ADMIN_AUTH["admin auth / x-api-key"]
            ACC_OPS["accounts operations<br/>status/schedulable/priority/concurrency<br/>credentials.model_mapping is blocked by DB constraint"]
            GROUP_OPS["groups operations<br/>platform/model_routing/supported scopes"]
            TEST_OPS["test_account / scheduled tests / clear_error"]
            KEY_OPS["api_keys operations<br/>group binding/status/quota"]
            ADMIN_AUTH --> ACC_OPS
            ADMIN_AUTH --> GROUP_OPS
            ADMIN_AUTH --> TEST_OPS
            ADMIN_AUTH --> KEY_OPS
        end

        subgraph ROUTER_SURFACE["15. Router surface / server/router.go + routes/*"]
            direction TB
            GLOBAL_MW["global middleware<br/>RequestLogger / Logger / CORS<br/>SecurityHeaders dynamic frame-src<br/>embedded frontend middleware"]
            COMMON_ROUTES["common routes<br/>health/status/static/frontend"]
            AUTH_ROUTES["/api/v1/auth<br/>register/login/logout/refresh<br/>OAuth connect callbacks<br/>verify code/password reset/settings"]
            USER_ROUTES["/api/v1/user + keys + groups + channels + usage<br/>profile/password/email/TOTP<br/>API key CRUD and available groups<br/>redeem/subscriptions/channel monitors"]
            PAYMENT_ROUTES["/api/v1/payment<br/>orders create/list/detail/cancel/resume/refund<br/>public plans/providers/config<br/>provider webhooks<br/>admin payment plans/providers/orders/stats"]
            ADMIN_ROUTES["/api/v1/admin<br/>dashboard/users/groups/accounts<br/>OAuth/proxies/redeem/promo/settings<br/>data/backups/system/subscriptions/usage<br/>ops/scheduled tests/channels/monitors/affiliate"]
