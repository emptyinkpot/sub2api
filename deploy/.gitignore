# =============================================================================
# Sub2API Deploy Directory - Git Ignore
# =============================================================================

# Data directories (generated at runtime when using docker-compose.local.yml)
data/
postgres_data/
redis_data/

# Environment configuration (contains sensitive information)
.env

# Backup files
*.backup
*.bak

# Temporary files
*.tmp
*.log

# Sensitive backups and exports (contain credentials/secrets — never commit)
secrets/
.env.backup*
*backup*.sql
docker-compose.yml.*
*.container.backup.*
