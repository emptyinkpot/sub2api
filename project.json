        "buildContainer": "golang:1.26.2-alpine",
        "sourceRoot": "/srv/sub2api",
        "outputPath": "/tmp/sub2api-build/sub2api",
        "targetContainer": "sub2api",
        "targetBinary": "/app/sub2api",
        "restartScope": "sub2api container only",
        "postVerify": [
